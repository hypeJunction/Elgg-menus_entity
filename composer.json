{
	"name": "hypejunction/menus_entity",
	"type": "elgg-plugin",
	"description": "Dropdown entity menu for Elgg",
	"homepage": "https://github.com/hypeJunction/Elgg-menus_entity",
	"keywords": [
		"elgg",
		"plugin",
		"ui",
		"menus",
		"dropdown",
		"entity"
	],
	"license": "GPL-2.0-only",
	"authors": [
		{
			"name": "Ismayil Khayredinov",
			"email": "ismayil.khayredinov@gmail.com"
		}
	],
	"extra": {
		"installer-name": "menus_entity",
		"elgg-plugin": {
			"id": "menus_entity"
		}
	},
	"require": {
		"php": ">=8.1",
		"ext-intl": "*",
		"composer/installers": "^2.0",
		"hypejunction/menus_dropdown": "~6.0",
		"elgg/elgg": "~6.1.0"
	},
	"autoload": {
		"psr-4": {
			"hypeJunction\\MenusEntity\\": "classes/hypeJunction/MenusEntity/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	}
}
